# ========================================
# Robot Live Console - Environment Configuration
# ========================================

# ----------------------------------------
# Environment Settings
# ----------------------------------------
ENVIRONMENT=production  # production | development

# ----------------------------------------
# Security (REQUIRED)
# All token types (access JWT, email verification, password reset)
# are signed with this single secret key.
# Generate with: openssl rand -hex 64
# ----------------------------------------
JWT_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_64

# ----------------------------------------
# Server / Public URL Configuration
# ----------------------------------------
# Public-facing URL of the frontend application.
# Used to build email verification and password-reset links.
APP_PUBLIC_BASE_URL=https://anybot.brainswarmrobotics.com

# Backend host (used internally by some services)
SERVER_HOST=https://anybot.brainswarmrobotics.com
VPS_URL=https://anybot.brainswarmrobotics.com
HOST=0.0.0.0
PORT=8000

# ----------------------------------------
# Email Configuration (REQUIRED for registration)
# Primary delivery via Resend API - no SMTP needed.
# Domain: contact.anybot.brainswarmrobotics.com (must be verified in Resend)
# ----------------------------------------
RESEND_API_KEY=re_your_resend_api_key_here
MAIL_FROM=no-reply@contact.anybot.brainswarmrobotics.com

# ----------------------------------------
# Google OAuth (REQUIRED for Google login)
# ----------------------------------------
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ----------------------------------------
# Database Configuration
# ----------------------------------------
DATABASE_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=robot_console
MYSQL_PASSWORD=your_secure_password_here
MYSQL_DATABASE=robot_console_db

# ----------------------------------------
# CORS Configuration
# ----------------------------------------
PRODUCTION_CORS_ORIGINS=https://anybot.brainswarmrobotics.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------------------------------
# Rate Limiting (Optional)
# ----------------------------------------
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=memory://

# ----------------------------------------
# Theia IDE Configuration (Optional)
# ----------------------------------------
THEIA_BASE_PORT=4000
THEIA_MAX_PORT=9000
THEIA_MAX_CONTAINERS=50
THEIA_PROJECT_PATH=./projects
# Preview image used for normal (non-booking) users
THEIA_PREVIEW_IMAGE=elswork/theia
# Booking image used when a user has an active booking session
THEIA_BOOKING_IMAGE=muneeb/theia-ros-humble:v1
# Legacy fallback — used as the preview image when THEIA_PREVIEW_IMAGE is not set
THEIA_IMAGE=elswork/theia

# ----------------------------------------
# WebRTC Bridge Configuration (Optional)
# ----------------------------------------
BRIDGE_WS_URL=ws://localhost:8081
BRIDGE_CONTROL_URL=http://localhost:8081/control

# ----------------------------------------
# Docker Configuration (Optional)
# ----------------------------------------
DOCKER_NETWORK=robot-console-network

# ----------------------------------------
# Video Storage Configuration (Optional)
# ----------------------------------------
VIDEO_STORAGE_PATH=./videos
MAX_VIDEO_SIZE_MB=100
