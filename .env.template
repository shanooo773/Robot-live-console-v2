# Database Configuration
# MySQL database settings (SQLite support removed)
DATABASE_URL=mysql://robot_console:1122root@localhost:3306/robot_console
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=robot_console
MYSQL_PASSWORD=1122root
MYSQL_DATABASE=robot_console
# Database type (MySQL only)
DATABASE_TYPE=mysql

# JWT Secret Key for Authentication (REQUIRED - use long random string)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-jwt-secret-key-must-be-very-long-and-random-at-least-64-characters

# Email Configuration (REQUIRED in production)
# For Gmail: use your Gmail address and an App Password (not your regular password)
# Generate App Password at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Google OAuth Configuration (REQUIRED for Google Sign-In)
# Get your Client ID from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server Configuration
HOST=0.0.0.0
PORT=8000
# Full server URL for email confirmation and password reset links
# MUST be HTTPS in production for secure cookies
SERVER_HOST=http://localhost:8000

# Frontend URL for password reset redirects
FRONTEND_URL=http://localhost:3000

# CORS Origins (comma-separated URLs)
# Development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
# Production - update with your actual domain
# PRODUCTION_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Environment Mode
ENVIRONMENT=development
# Set to production on deployment server
# ENVIRONMENT=production

# Video Storage Configuration
VIDEO_STORAGE_PATH=./videos
MAX_VIDEO_SIZE_MB=100

# Admin Configuration (first admin account)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-in-production

# Environment Mode
ENVIRONMENT=development
# Set to production on deployment server
# ENVIRONMENT=production

# Eclipse Theia IDE Configuration
THEIA_BASE_PORT=4000
THEIA_MAX_PORT=9000
THEIA_MAX_CONTAINERS=50
THEIA_PROJECT_PATH=./projects
THEIA_IMAGE=elswork/theia

# WebRTC Signaling Configuration
WEBRTC_SIGNALING_PORT=8080
WEBRTC_STUN_PORT=3478
WEBRTC_TURN_PORT=5349
WEBRTC_ICE_RANGE_START=50000
WEBRTC_ICE_RANGE_END=50100

# Docker Network Configuration
DOCKER_NETWORK=robot-console-network
