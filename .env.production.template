# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to backend/.env and update the values for your VPS deployment

# Database Configuration
DATABASE_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=robot_console
MYSQL_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
MYSQL_DATABASE=robot_console

# JWT Secret Key — used for ALL token types (access, email verification, password reset).
# Generate a strong random key: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_64_HEX_CHARS

# Email delivery via Resend API (https://resend.com)
# Domain contact.anybot.brainswarmrobotics.com must be verified in your Resend account.
RESEND_API_KEY=re_your_resend_api_key_here
MAIL_FROM=no-reply@contact.anybot.brainswarmrobotics.com

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Public-facing frontend URL — used for email verification and password-reset links
APP_PUBLIC_BASE_URL=https://anybot.brainswarmrobotics.com

# CORS Origins — update with your actual domain
PRODUCTION_CORS_ORIGINS=https://anybot.brainswarmrobotics.com

# Server Configuration
HOST=0.0.0.0
PORT=8000
SERVER_HOST=https://anybot.brainswarmrobotics.com
VPS_URL=https://anybot.brainswarmrobotics.com

# Theia IDE Configuration
THEIA_IMAGE=elswork/theia
THEIA_BOOKING_IMAGE=muneeb/theia-ros-humble:v2
# Comma-separated list of additional Docker images admins may choose for surveillance containers.
# ALLOWED_SURVEILLANCE_IMAGES=my-org/custom-ros:humble

# Video Storage Configuration
VIDEO_STORAGE_PATH=./videos
MAX_VIDEO_SIZE_MB=100

# CRITICAL: Set to production for VPS deployment
ENVIRONMENT=production

# DEPLOYMENT NOTES:
# 1. Replace all placeholder values above with actual production values.
# 2. Generate a strong JWT_SECRET_KEY with: openssl rand -hex 64
# 3. Obtain RESEND_API_KEY from https://resend.com and verify your domain.
# 4. Use HTTPS URLs in PRODUCTION_CORS_ORIGINS for SSL-enabled domains.
# 5. Ensure ENVIRONMENT=production for production deployment.
# 6. Keep this file secure (permissions 600, owned by the service user).
